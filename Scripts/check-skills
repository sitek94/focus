#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SOURCES="$ROOT/.agents/skills/SOURCES.md"
NOTICES="$ROOT/THIRD_PARTY_NOTICES.md"
SKILLS_DIR="$ROOT/.agents/skills"

if [[ ! -f "$SOURCES" ]]; then
  echo "check-skills: missing $SOURCES" >&2
  exit 1
fi

if [[ ! -f "$NOTICES" ]]; then
  echo "check-skills: missing $NOTICES" >&2
  exit 1
fi

fail=0

require_field() {
  local file="$1"
  local pattern="$2"
  local label="$3"
  if ! grep -Eq "$pattern" "$file"; then
    echo "check-skills: $file missing $label" >&2
    fail=1
  fi
}

# Rows: | `skill-name` | ...
while IFS= read -r line; do
  skill="$(sed -E 's/^\|[[:space:]]*`?([a-z0-9-]+)`?.*/\1/' <<<"$line")"
  [[ "$skill" =~ ^(focus-|release-) ]] || continue

  if ! grep -Fq "$skill" "$NOTICES"; then
    echo "check-skills: '$skill' listed in SOURCES.md but not in THIRD_PARTY_NOTICES.md" >&2
    fail=1
  fi

  skill_md="$SKILLS_DIR/$skill/SKILL.md"
  if [[ ! -f "$skill_md" ]]; then
    echo "check-skills: missing $skill_md" >&2
    fail=1
    continue
  fi

  # YAML / provenance header fields required for every Focus skill.
  require_field "$skill_md" '^name:[[:space:]]*'"$skill"'$' "name: $skill"
  require_field "$skill_md" '^disposition:[[:space:]]*(adapted|original)$' "disposition"
  require_field "$skill_md" '^license:[[:space:]]' "license"
  require_field "$skill_md" '^upstream:[[:space:]]' "upstream"

  disposition="$(grep -E '^disposition:' "$skill_md" | head -1 | awk '{print $2}')"
  case "$disposition" in
    adapted)
      commit="$(grep -E '^commit:' "$skill_md" | head -1 | awk '{print $2}')"
      if [[ ! "$commit" =~ ^[0-9a-f]{40}$ ]]; then
        echo "check-skills: $skill_md commit must be a full 40-char SHA (got '${commit:-empty}')" >&2
        fail=1
      elif ! grep -Fq "$commit" "$NOTICES"; then
        echo "check-skills: $skill commit $commit not found in THIRD_PARTY_NOTICES.md" >&2
        fail=1
      elif ! grep -Fq "$commit" "$SOURCES"; then
        echo "check-skills: $skill commit $commit not found in SOURCES.md" >&2
        fail=1
      fi

      require_field "$skill_md" '^license:[[:space:]]*MIT$' "license: MIT"
      require_field "$skill_md" '^upstream:[[:space:]]*https://' "https upstream URL"
      require_field "$skill_md" '^source_paths:' "source_paths"
      require_field "$skill_md" 'Disposition \| \*\*adapted\*\*' "Provenance disposition adapted"
      if ! grep -Eq 'source_paths:|[[:space:]]+-[[:space:]]+[^[:space:]]+\.(md|swift)' "$skill_md"; then
        echo "check-skills: $skill_md source_paths must list at least one path" >&2
        fail=1
      fi
      # Reject accidental PolyForm / dpearson provenance.
      if grep -Eiq 'dpearson|polyform|swift-ios-skills' "$skill_md"; then
        echo "check-skills: $skill_md must not reference PolyForm / dpearson material" >&2
        fail=1
      fi
      ;;
    original)
      require_field "$skill_md" '^upstream:[[:space:]]*Focus-authored$' "upstream: Focus-authored"
      require_field "$skill_md" 'Disposition \| \*\*original\*\*' "Provenance disposition original"
      ;;
    *)
      echo "check-skills: $skill_md unknown disposition '$disposition'" >&2
      fail=1
      ;;
  esac
done < <(grep -E '^\| `?[a-z0-9-]+`?' "$SOURCES" || true)

# Notices must not claim planned placeholders for the four curated skills.
if grep -Eiq 'adapted \(planned\)|original \(planned\)|\(planned\)' "$NOTICES"; then
  echo "check-skills: THIRD_PARTY_NOTICES.md still contains planned placeholders" >&2
  fail=1
fi

if grep -Eiq '\(planned\)' "$SOURCES"; then
  echo "check-skills: SOURCES.md still contains planned placeholders" >&2
  fail=1
fi

if [[ "$fail" -ne 0 ]]; then
  exit 1
fi

echo "check-skills: ok (SOURCES.md ↔ THIRD_PARTY_NOTICES.md ↔ SKILL.md headers)"
